{
  "manifest_version": 3,
  "name": "FB Profile Authenticity Analyzer",
  "version": "1.0.0",
  "description": "Detects fake Facebook profiles using 9-signal weighted scoring. Works on any profile page — no login required for public profiles.",
  "permissions": ["activeTab"],
  "host_permissions": ["https://www.facebook.com/*", "https://facebook.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.facebook.com/*", "https://facebook.com/*"],
      "js": ["gender.js", "analyzer.js", "collector.js", "content.js"],
      "css": ["overlay.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
